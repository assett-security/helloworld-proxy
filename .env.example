# Cloudflare Worker Proxy Configuration (Open/No Auth)
# Copy this file to .env and fill in your values

# Cloudflare Account ID (get from: wrangler whoami)
CLOUDFLARE_ACCOUNT_ID=

# Proxy URL (will be provided after first deployment)
# Format: https://helloworld-proxy.your-username.workers.dev
PROXY_URL=

# Optional: Custom domain for proxy
# PROXY_CUSTOM_DOMAIN=proxy.yourdomain.com

# NOTE: This is an OPEN PROXY without authentication!
# No API key required. Anyone with the URL can use it.
# Only use for personal projects or behind a firewall.
